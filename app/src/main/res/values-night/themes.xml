<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.HospitalSanPedro" parent="Theme.MaterialComponents.Light.NoActionBar">

        <!-- Evitar modo oscuro (corrección con tools:targetApi) -->
        <item name="android:forceDarkAllowed" tools:targetApi="29">false</item>

        <!-- Colores principales -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Colores secundarios -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Fondo de la app (corrección sin android:) -->
        <item name="android:colorBackground">@color/white</item>

        <item name="colorSurface">@color/white</item>
        <item name="colorOnBackground">@color/black</item>
        <item name="colorOnSurface">@color/black</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/purple_700</item>

    </style>

    <!-- ShapeAppearanceOverlay para TextInputLayout redondeado -->
    <style name="ShapeAppearanceOverlay.MyRoundedCorners" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>


</resources>
